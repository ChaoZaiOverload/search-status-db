{
  "manifest_version": 3,
  "name": "Douban Status Search",
  "version": "1.1.0",
  "description": "Search your Douban main feed statuses by keyword",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://www.douban.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.douban.com/", "https://www.douban.com/?*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
